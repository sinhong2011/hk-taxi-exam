---
interface Props { activeTab: string; }
const { activeTab } = Astro.props;

const referenceIds = ["regulations", "fares", "places", "routes", "roadcode"];
const isOnReference = referenceIds.includes(activeTab);

const referenceTabs = [
  { id: "regulations", label: "則例", href: "/regulations" },
  { id: "fares", label: "收費", href: "/fares" },
  { id: "places", label: "地方", href: "/places" },
  { id: "routes", label: "路線", href: "/routes" },
  { id: "roadcode", label: "道路守則", href: "/roadcode" },
];
---

<nav class="bnav" aria-label="主導航">
  <a href="/" class={`btab ${activeTab === "overview" ? "active" : ""}`} aria-label="總覽">
    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 11 12 4l9 7v9a1 1 0 0 1-1 1h-5v-7h-6v7H4a1 1 0 0 1-1-1z"/></svg>
    <span>總覽</span>
  </a>
  <button type="button" class={`btab ${isOnReference ? "active" : ""}`} data-open-chapters aria-label="章節" aria-haspopup="dialog">
    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 4h7a3 3 0 0 1 3 3v13a2 2 0 0 0-2-2H4zM20 4h-7a3 3 0 0 0-3 3v13a2 2 0 0 1 2-2h8z"/></svg>
    <span>章節</span>
  </button>
  <a href="/quiz" class={`btab ${activeTab === "quiz" ? "active" : ""}`} aria-label="測驗">
    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 3h11l4 4v14H5zm11 0v4h4M8 13h8M8 17h5"/></svg>
    <span>測驗</span>
  </a>
  <a href="/mock" class={`btab ${activeTab === "mock" ? "active" : ""}`} aria-label="模擬試">
    <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="4" y="3" width="16" height="18" rx="2"/><path d="M9 8h6M9 12h6M9 16h4"/></svg>
    <span>模擬試</span>
  </a>
</nav>

<dialog class="sheet" data-chapters-sheet aria-label="選擇章節">
  <div class="sheet-inner">
    <div class="sheet-handle" aria-hidden="true"></div>
    <div class="sheet-head">
      <strong>章節</strong>
      <button type="button" class="sheet-close" data-close-chapters aria-label="關閉">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 6l12 12M18 6 6 18"/></svg>
      </button>
    </div>
    <div class="sheet-list" role="list">
      {referenceTabs.map((t) => (
        <a
          href={t.href}
          class={`sheet-item ${activeTab === t.id ? "active" : ""}`}
          role="listitem"
        >
          <span>{t.label}</span>
          <svg viewBox="0 0 24 24" aria-hidden="true" class="sheet-chev"><path d="m9 6 6 6-6 6"/></svg>
        </a>
      ))}
    </div>
  </div>
</dialog>

<script>
  function setupChapterSheet() {
    const sheet = document.querySelector<HTMLDialogElement>("[data-chapters-sheet]");
    const openBtn = document.querySelector<HTMLButtonElement>("[data-open-chapters]");
    const closeBtn = document.querySelector<HTMLButtonElement>("[data-close-chapters]");
    if (!sheet || !openBtn) return;

    openBtn.addEventListener("click", () => sheet.showModal());
    closeBtn?.addEventListener("click", () => sheet.close());
    sheet.addEventListener("click", (e) => {
      const rect = sheet.getBoundingClientRect();
      const inDialog =
        e.clientY >= rect.top && e.clientY <= rect.bottom &&
        e.clientX >= rect.left && e.clientX <= rect.right;
      if (!inDialog) sheet.close();
    });
  }

  setupChapterSheet();
  document.addEventListener("astro:after-swap", setupChapterSheet);
</script>
