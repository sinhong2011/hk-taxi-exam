---
interface Props { activeTab: string; }
const { activeTab } = Astro.props;

const tabs = [
  { id: "overview", label: "總覽", href: "/" },
  { id: "regulations", label: "則例", href: "/regulations" },
  { id: "fares", label: "收費", href: "/fares" },
  { id: "places", label: "地方", href: "/places" },
  { id: "routes", label: "路線", href: "/routes" },
  { id: "roadcode", label: "道路守則", href: "/roadcode" },
  { id: "quiz", label: "測驗", href: "/quiz" },
  { id: "mock", label: "模擬試", href: "/mock" },
  { id: "leaderboard", label: "龍虎榜", href: "/leaderboard" },
];
---

<div class="tabs-wrap" data-tabs-wrap data-scroll-start="true" data-scroll-end="true">
  <nav class="tabs" role="tablist" data-tabs>
    {tabs.map((t, i) => (
      <a
        href={t.href}
        class={`tab ${activeTab === t.id ? "active" : ""}`}
        role="tab"
        aria-selected={activeTab === t.id}
        data-tab-id={t.id}
      >
        <span class="tab-num">{String(i + 1).padStart(2, "0")}</span>
        {t.label}
        {activeTab === t.id && <span class="tab-underline" transition:name="tab-underline"></span>}
      </a>
    ))}
  </nav>
</div>

<script>
  function setupTabs() {
    const wrap = document.querySelector<HTMLElement>("[data-tabs-wrap]");
    const scroller = document.querySelector<HTMLElement>("[data-tabs]");
    if (!wrap || !scroller) return;

    const updateEdges = () => {
      const { scrollLeft, scrollWidth, clientWidth } = scroller;
      const atStart = scrollLeft <= 1;
      const atEnd = scrollLeft + clientWidth >= scrollWidth - 1;
      wrap.dataset.scrollStart = String(atStart);
      wrap.dataset.scrollEnd = String(atEnd);
    };

    const active = scroller.querySelector<HTMLElement>(".tab.active");
    if (active) {
      const aLeft = active.offsetLeft;
      const aRight = aLeft + active.offsetWidth;
      const viewLeft = scroller.scrollLeft;
      const viewRight = viewLeft + scroller.clientWidth;
      if (aLeft < viewLeft || aRight > viewRight) {
        const target = aLeft - (scroller.clientWidth - active.offsetWidth) / 2;
        scroller.scrollLeft = Math.max(0, target);
      }
    }

    updateEdges();
    scroller.addEventListener("scroll", updateEdges, { passive: true });
    window.addEventListener("resize", updateEdges);
  }

  setupTabs();
  document.addEventListener("astro:after-swap", setupTabs);
</script>
