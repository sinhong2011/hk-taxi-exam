---
import BaseLayout from "../layouts/BaseLayout.astro";
import { roadSections } from "../data/roadCode";
import catalog from "../../public/signs/catalog.json";

type SignEntry = { category: string; file: string; caption: string };
const signs = catalog as SignEntry[];

const signCategories = Array.from(new Set(signs.map((e) => e.category)));
const signGrouped = signCategories.map((cat) => ({
  cat,
  items: signs.filter((e) => e.category === cat),
}));
---

<BaseLayout activeTab="roadcode" title="道路守則・的士筆試">
  <div class="mb-8 flex items-baseline gap-4">
    <span class="font-mono text-[11px] tracking-[0.12em] text-muted uppercase">06</span>
    <h2 class="font-serif text-[clamp(24px,4vw,32px)] leading-[1.2] font-medium tracking-[-0.015em]">道路使用者守則・駕駛人篇</h2>
  </div>

  <p class="mb-2 max-w-(--container-reading) text-base leading-[1.75] text-ink-2">
    摘錄《道路使用者守則》第五、八、十章與駕駛人／職業司機最相關的內容，
    涵蓋速度、距離、超車、行人、緊急事故等高頻考點。
  </p>

  <div class="flex flex-col">
    {roadSections.map((s, i) => (
      <section class="grid grid-cols-[100px_minmax(0,1fr)] gap-8 py-10 max-tablet:grid-cols-[60px_minmax(0,1fr)] max-tablet:gap-5 max-tablet:py-8">
        <div>
          <div class="font-serif text-[56px] leading-none font-normal tracking-[-0.03em] text-red tabular-nums max-tablet:text-[40px]">
            {String(i + 1).padStart(2, "0")}
          </div>
          <div class="mt-2 text-[11px] tracking-[0.14em] text-muted uppercase">守則要點</div>
        </div>
        <div>
          <h3 class="mb-2.5 font-serif text-[26px] leading-[1.25] font-medium tracking-[-0.01em] max-tablet:text-[22px]">
            {s.title}
          </h3>
          <div class="mt-2 grid grid-cols-3 gap-x-2 gap-y-3 max-tablet:grid-cols-1 max-tablet:gap-y-2">
            {s.tips.map((t) => (
              <div class="relative flex min-h-[70px] flex-col gap-1 px-4 py-3">
                <div class:list={[
                  "text-[12.5px] font-medium tracking-[0.02em] text-muted",
                  t.hot && "after:ml-2 after:inline-block after:size-[5px] after:-translate-y-[4px] after:rounded-full after:bg-red after:content-['']"
                ]}>{t.title}</div>
                <div class="text-[14.5px] leading-[1.55] text-ink [font-feature-settings:'tnum'_1]">{t.desc}</div>
              </div>
            ))}
          </div>
        </div>
      </section>
    ))}
  </div>

  <div id="catalog-標誌圖鑑" class="mt-18 mb-8 flex items-baseline gap-4">
    <span class="font-mono text-[11px] tracking-[0.12em] text-muted uppercase">07</span>
    <h2 class="font-serif text-[clamp(24px,4vw,32px)] leading-[1.2] font-medium tracking-[-0.015em]">交通標誌・原圖庫</h2>
  </div>

  <p class="mb-6 max-w-(--container-reading) text-base leading-[1.75] text-ink-2">
    共 {signs.length} 個標誌，圖片及名稱均來自運輸署《道路使用者守則》第八章。
    按類別分組瀏覽：紅圓＝禁制、紅三角＝警告、藍圓＝指令、藍方＝提示／方向。
  </p>

  <nav class="mb-8 flex flex-wrap gap-[18px] text-[13px]">
    {signCategories.map((c) => (
      <a
        href={`#cat-${c}`}
        class="py-0.5 tracking-[0.02em] text-muted transition-colors hover:text-red"
      >{c}</a>
    ))}
  </nav>

  {signGrouped.map(({ cat, items }) => (
    <section id={`cat-${cat}`} class="mb-14 scroll-mt-[120px]">
      <header class="mb-5 flex items-baseline justify-between py-3">
        <span class="font-mono text-[11px] tracking-[0.12em] text-muted uppercase">{cat}</span>
        <span class="font-serif text-[13px] text-muted tabular-nums">{items.length} 個</span>
      </header>
      <div class="grid grid-cols-[repeat(auto-fill,minmax(180px,1fr))] gap-x-4 gap-y-6 max-[520px]:grid-cols-[repeat(auto-fill,minmax(140px,1fr))] max-[520px]:gap-x-2.5 max-[520px]:gap-y-3.5">
        {items.map((e) => (
          <figure class="flex flex-col items-stretch gap-2 rounded bg-paper-2 px-2.5 pt-3 pb-3.5 transition-all hover:-translate-y-px hover:bg-paper-raised max-[520px]:px-1.5 max-[520px]:pt-2 max-[520px]:pb-2.5">
            <div class="grid aspect-square w-full place-items-center rounded-[3px] bg-white p-2.5">
              <img
                src={`/signs/${e.file}`}
                alt={e.caption || e.file}
                loading="lazy"
                decoding="async"
                class="max-h-full max-w-full object-contain"
              />
            </div>
            <figcaption class="min-h-[2.9em] px-0.5 text-center text-[12.5px] leading-[1.45] text-ink-2 max-[520px]:min-h-[2.6em] max-[520px]:text-[11.5px]">
              {e.caption || "（未提供標題）"}
            </figcaption>
            <div class="flex items-center justify-between gap-2 pt-1.5">
              <span class="font-mono text-[9.5px] tracking-[0.04em] text-muted uppercase">{e.category}</span>
              <span class="font-mono text-[9.5px] tracking-[0.02em] text-muted tabular-nums">{e.file.replace(/\.(gif|png|jpg)$/, "")}</span>
            </div>
          </figure>
        ))}
      </div>
    </section>
  ))}
</BaseLayout>
